   git clone -b main https://github.com/NGWPC/nwm.v3.0.6_no_svn.git /ngen-app/nwm.v3.0.6

RUN set -eux; mkdir -p /ngen-app/nwm.v3.0.6/exec

RUN set -eux;  mkdir -p /ngen-app/nwm.v3.0.6/parm

