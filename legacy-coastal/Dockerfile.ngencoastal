#build the SCHISM binaries
RUN set -eux; \
    \
    cd /ngen-app/nwm.v3.0.6/sorc/schism/; \
    source ./build_schism_cmake_docker.sh; \
    cd /ngen-app/nwm.v3.0.6/sorc/combine_sink_source; \
    make; \
    cp combine_sink_source ../../exec;\
    cd /ngen-app/nwm.v3.0.6/sorc/combine_hotstart7; \
    make; \
    cp combine_hotstart7 ../../exec; \
    cd /ngen-app/nwm.v3.0.6/sorc/metis_prep; \
    make clean; make; \
    cp metis_prep ../../exec; \
    cd /ngen-app/nwm.v3.0.6/sorc/metis; \
    source ./build_metis_docker.sh; \
    cd -

# Sparse clone of ngen-forcing for forcings engine, ESMF mesh, and extraction scripts.
# These are placed at /ngen-app/ngen-forcing/ because upstream code has hardcoded paths to that location.
ARG NGEN_FORCING_ORG=NGWPC
ARG NGEN_FORCING_REF=development

# Try shallow clone by branch/tag name first; fall back to full clone + checkout
# for bare commit SHAs (which git clone -b doesn't support).
RUN set -eux && \
    (git clone --filter=blob:none --sparse --depth 1 -b "${NGEN_FORCING_REF}" \
        "https://github.com/${NGEN_FORCING_ORG}/ngen-forcing.git" /ngen-app/ngen-forcing \
     || (git clone --filter=blob:none --sparse \
            "https://github.com/${NGEN_FORCING_ORG}/ngen-forcing.git" /ngen-app/ngen-forcing && \
         cd /ngen-app/ngen-forcing && git checkout "${NGEN_FORCING_REF}")) && \
    cd /ngen-app/ngen-forcing && \
    git sparse-checkout set \
      NextGen_Forcings_Engine_BMI \
      ESMF_Mesh_Domain_Configuration_Production \
      Forcing_Extraction_Scripts

ENV CONDA_ENVS_PATH=/ngen-app/conda/envs/

ARG CONDA_ENV_NAME=ngen_forcing_coastal
COPY ./environment.yml environment.yaml
RUN set -eux; \
    \
    conda init

RUN set -eux; \
    \
    conda env create --name ${CONDA_ENV_NAME} --file=environment.yaml ; \
    conda clean --all --yes ; \
    rm --force environment.yaml

#RUN set -eux; \
#    \
#    conda init bash
#RUN set -eux; \
#    \
#    conda init ${CONDA_ENV_NAME}

#ARG OLD_PATH=${PATH}
#ENV PATH=${CONDA_ENVS_PATH}/${CONDA_ENV_NAME}/bin:${PATH}

ARG CONDA_ENV_NAME=ngen_forcings_engine_bmi
RUN set -eux; \
    \
    cp /ngen-app/ngen-forcing/NextGen_Forcings_Engine_BMI/environment.yml environment.yaml ; \
    conda env create --name ${CONDA_ENV_NAME} --file=environment.yaml ; \
    conda clean --all --yes ; \
    rm --force environment.yaml

ARG CONDA_ENV_NAME=ngen_esmf_mesh_domain
RUN set -eux; \
    \
    cp /ngen-app/ngen-forcing/ESMF_Mesh_Domain_Configuration_Production/environment.yml environment.yaml ; \
    conda env create --name ${CONDA_ENV_NAME} --file=environment.yaml ; \
    conda clean --all --yes ; \
    conda run -n ${CONDA_ENV_NAME} pip install --upgrade geopandas ; \
    rm --force environment.yaml

ENV WGRIB2=/usr/local/bin/wgrib2

#ENV PATH=${OLD_PATH}

COPY . /ngen-app/nwm-coastal/legacy-coastal/

WORKDIR /ngen-app/

ENV COASTAL_VENV="/ngen-app/ngen-coastal-venv"
RUN set -eux; python3 -m venv ${COASTAL_VENV}

RUN --mount=type=cache,target=/root/.cache/pip,id=pip-cache \
    set -eux && \
    ${COASTAL_VENV}/bin/python -m pip install -r ./nwm-coastal/legacy-coastal/forecast/requirements.txt

ENV SFINCS_VENV="/ngen-app/ngen-sfincs-venv"
RUN set -eux; python3 -m venv ${SFINCS_VENV}

RUN --mount=type=cache,target=/root/.cache/pip,id=pip-cache \
    set -eux && \
    ${SFINCS_VENV}/bin/python -m pip install -r ./nwm-coastal/legacy-coastal/SFINCS/requirements.txt

RUN set -eux; \
    \
    rm --force /root/.gitconfig

WORKDIR /
SHELL ["/bin/bash", "-c"]

ENTRYPOINT [ "/bin/bash" ]
